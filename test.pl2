fn alloc(size i64) *void {
@output stack ("
load.d 0
alloc
ret.d
; unreachable: ");

    return cast(*void) 0;
}

fn print(string *i8, size i64) i32 {
@output stack ("
push 1 ; stdout
load.d 0
load.d 2
push 4 ; write
system
ret.w
; unreachable: ")

    // TODO
    return cast(i32) 0;
}

struct ByteArray {
    len i64;
    cap i64;
    ptr *i8;
}

fn ByteArray_push(self *ByteArray, x i8) {
    if self.cap == 0 {
        self.cap = 128;
    }

    if self.ptr == cast(*i8) 0 {
        self.ptr = cast(*i8) alloc(self.cap * 1)
    }

    if self.len == self.cap {
        self.cap = self.cap * 2;
        let ptr = cast(*i8) alloc(self.cap * 1);
        // copy (or implement realloc?)
        self.ptr = ptr;
    }

    // TODO
    let ptr = self.ptr;
    ptr[self.len] = x;

    self.len = self.len + 1;

    return;
}

fn main() void {
