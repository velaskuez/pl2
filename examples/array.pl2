    let s = "Hello, World!";

    // TODO(stack): call should only pop off the arguments
    // it needs. Maybe this can be accomplished by some sort
    // of annotation next to the label/call inst. For now, we
    // can't call functions within an expression as it clears
    // the stack.
    let len = strlen(s);
    print(s, len);

    return;
}
